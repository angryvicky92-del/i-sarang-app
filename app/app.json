{
  "expo": {
    "name": "얼집체크",
    "slug": "uljip-check",
    "scheme": "app",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/custom_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/custom_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uljipcheck.app",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.uljipcheck.app",
      "versionCode": 5,
      "softwareKeyboardLayoutMode": "adjustResize",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/custom_icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser",
      "expo-notifications",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2170284484198182~1980683779",
          "iosAppId": "ca-app-pub-2170284484198182~2888344837"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2ef1be03-92ce-4b7d-84f5-a115730f58a8"
      }
    }
  }
}
